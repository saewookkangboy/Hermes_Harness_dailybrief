# Research squad raw (regenerated)
content/research/raw/*

# Generated wiki runtime
content/wiki/_ingest_queue.json
content/wiki/output/*
content/research/_brief_graph.json

# Generated newsletter outputs
content/newsletter/*

# Notion local state
content/.notion-archive-state.json
content/.notion-architecture-state.json

# Generated content (keep structure)
content/blog/*.html
content/instagram/*.md
content/linkedin/*.md
content/lectures/*
content/packages/*
content/logs/*
content/drafts/**/*
!content/drafts/cursor-handoff/.gitkeep

# Search context cache (regenerated daily)
content/research/_search_context_*

# Cron exports
cron-exports/*
