# Secrets & local env
.env
.env.*
*.pem
credentials.json
**/credentials/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# macOS
.DS_Store

# Personal / private outputs
content/personal/

# Harness runtime traces & logs
.harness/traces/
.harness/*.log
.harness/eval-results.json
.harness/handoffs/
.harness/jobs/
.harness/publish-queue/
.harness/sessions/
